pipeline {
    agent any

    triggers {
        cron('*/5 * * * *')
    }

    stages {

        stage('Build Maven') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t yourdockerhubusername/java-k8s-cron-app:v1 .'
            }
        }

        stage('Push Docker Image') {
            steps {
                sh 'docker push yourdockerhubusername/java-k8s-cron-app:v1'
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                sh 'kubectl apply -f deployment.yaml'
                sh 'kubectl apply -f service.yaml'
            }
        }

    }
}


apiVersion: v1
kind: Service

metadata:
  name: java-service

spec:
  selector:
    app: java-app

  ports:
  - port: 8080
    targetPort: 8080

  type: NodePort


apiVersion: apps/v1
kind: Deployment

metadata:
  name: java-app

spec:
  replicas: 2

  selector:
    matchLabels:
      app: java-app

  template:
    metadata:
      labels:
        app: java-app

    spec:
      containers:
      - name: java-app
        image: yourdockerhubusername/java-k8s-cron-app:v1


